FROM node:22-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/web/package.json ./apps/web/
COPY libs/shared/package.json ./libs/shared/
RUN npm install -g pnpm@latest --quiet
RUN pnpm install --frozen-lockfile

FROM node:22-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm@latest --quiet
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/.npmrc ./.npmrc
COPY . .
ENV API_BASE_URL=http://the-swagger-api:4200
RUN pnpm --filter @the-swagger/web install --frozen-lockfile
RUN pnpm --filter @the-swagger/shared build 2>/dev/null || true
RUN pnpm --filter @the-swagger/web build

FROM node:22-alpine AS runner
WORKDIR /app
RUN apk add --no-cache wget
ENV NODE_ENV=production
ENV PORT=4000
ENV HOSTNAME=0.0.0.0
ENV API_BASE_URL=http://the-swagger-api:4200
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
RUN cp -r /app/apps/web/public ./apps/web/ 2>/dev/null || true
RUN chown -R nextjs:nodejs /app
USER nextjs
EXPOSE 4000
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD wget -qO- http://localhost:4000 || exit 1
CMD ["node", "apps/web/server.js"]
