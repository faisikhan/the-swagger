{
  "family": "the-swagger-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::559050236729:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::559050236729:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "the-swagger-api",
      "image": "559050236729.dkr.ecr.ap-south-1.amazonaws.com/the-swagger-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 4200,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "4200" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:559050236729:secret:the-swagger/database-url"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:559050236729:secret:the-swagger/jwt-secret"
        },
        {
          "name": "COOKIE_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:559050236729:secret:the-swagger/cookie-secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/the-swagger-api",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:4200/api/v1/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
